#!/usr/bin/env bash
# ============================================================
# chat-send — Send a message to a Google Chat space
#
# Uses Application Default Credentials (ADC) from the VM's
# service account to authenticate with the Google Chat API.
#
# Usage:
#   chat-send "Hello from Architect Prime!"
#   chat-send --card "Title" "Body text"
#   echo "message" | chat-send --stdin
#
# Environment:
#   CHAT_SPACE_ID  — Google Chat space ID (required)
#                    Format: spaces/AAAA...
#   GCP_PROJECT_ID — GCP project (for logging, optional)
#
# The Chat space ID is read from:
#   1. $CHAT_SPACE_ID env var
#   2. /opt/openclaw/.openclaw/corekit/chat-config.json
# ============================================================
set -euo pipefail

# ---- CONFIG ----
OC_HOST_ROOT="${OC_HOST_ROOT:-/opt/openclaw}"
CHAT_CONFIG="${OC_HOST_ROOT}/.openclaw/corekit/chat-config.json"
CHAT_API="https://chat.googleapis.com/v1"

# ---- Helpers ----
die() { echo "[ERROR] $*" >&2; exit 1; }

# ---- Resolve Chat space ID ----
resolve_space_id() {
  if [[ -n "${CHAT_SPACE_ID:-}" ]]; then
    echo "$CHAT_SPACE_ID"
    return
  fi
  if [[ -f "$CHAT_CONFIG" ]]; then
    # Extract spaceId from JSON (no jq dependency)
    local sid
    sid="$(grep -o '"spaceId"[[:space:]]*:[[:space:]]*"[^"]*"' "$CHAT_CONFIG" 2>/dev/null | head -1 | sed 's/.*: *"\([^"]*\)"/\1/')"
    if [[ -n "$sid" ]]; then
      echo "$sid"
      return
    fi
  fi
  die "No Chat space ID found. Set CHAT_SPACE_ID or configure chat-config.json"
}

# ---- Get access token via ADC (metadata server on GCE) ----
get_access_token() {
  local token
  token="$(curl -s -f \
    -H 'Metadata-Flavor: Google' \
    'http://metadata.google.internal/computeMetadata/v1/instance/service-accounts/default/token' \
    | grep -o '"access_token":"[^"]*"' | sed 's/"access_token":"\([^"]*\)"/\1/')"

  if [[ -z "$token" ]]; then
    die "Failed to get access token from metadata server. Is this running on a GCE VM?"
  fi
  echo "$token"
}

# ---- Send a simple text message ----
send_text() {
  local space_id="$1"
  local text="$2"
  local token
  token="$(get_access_token)"

  local response
  response="$(curl -s -w "\n%{http_code}" \
    -X POST \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "${CHAT_API}/${space_id}/messages" \
    -d "{\"text\": $(printf '%s' "$text" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')}")"

  local http_code
  http_code="$(echo "$response" | tail -1)"
  local body
  body="$(echo "$response" | sed '$d')"

  if [[ "$http_code" -ge 200 && "$http_code" -lt 300 ]]; then
    echo "[chat-send] Message sent to ${space_id} (HTTP ${http_code})"
  else
    echo "[chat-send] Failed to send message (HTTP ${http_code})" >&2
    echo "$body" >&2
    return 1
  fi
}

# ---- Send a card message ----
send_card() {
  local space_id="$1"
  local title="$2"
  local body="$3"
  local token
  token="$(get_access_token)"

  local payload
  payload="{
    \"cardsV2\": [{
      \"cardId\": \"status-card\",
      \"card\": {
        \"header\": {
          \"title\": $(printf '%s' "$title" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))'),
          \"imageUrl\": \"https://fonts.gstatic.com/s/i/short-term/release/googlesymbols/robot_2/default/48px.svg\",
          \"imageType\": \"CIRCLE\"
        },
        \"sections\": [{
          \"widgets\": [{
            \"textParagraph\": {
              \"text\": $(printf '%s' "$body" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')
            }
          }]
        }]
      }
    }]
  }"

  local response
  response="$(curl -s -w "\n%{http_code}" \
    -X POST \
    -H "Authorization: Bearer ${token}" \
    -H "Content-Type: application/json" \
    "${CHAT_API}/${space_id}/messages" \
    -d "$payload")"

  local http_code
  http_code="$(echo "$response" | tail -1)"

  if [[ "$http_code" -ge 200 && "$http_code" -lt 300 ]]; then
    echo "[chat-send] Card sent to ${space_id} (HTTP ${http_code})"
  else
    echo "[chat-send] Failed to send card (HTTP ${http_code})" >&2
    echo "$response" | sed '$d' >&2
    return 1
  fi
}

# ---- Main ----
SPACE_ID="$(resolve_space_id)"

case "${1:-}" in
  --card)
    [[ -n "${2:-}" ]] || die "Usage: chat-send --card <title> <body>"
    [[ -n "${3:-}" ]] || die "Usage: chat-send --card <title> <body>"
    send_card "$SPACE_ID" "$2" "$3"
    ;;
  --stdin)
    text="$(cat)"
    [[ -n "$text" ]] || die "No input on stdin"
    send_text "$SPACE_ID" "$text"
    ;;
  --help|-h)
    echo "Usage: chat-send <message>"
    echo "       chat-send --card <title> <body>"
    echo "       echo 'msg' | chat-send --stdin"
    ;;
  "")
    die "Usage: chat-send <message>"
    ;;
  *)
    send_text "$SPACE_ID" "$1"
    ;;
esac
